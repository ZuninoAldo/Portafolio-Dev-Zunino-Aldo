---
import IconGithub from "../components/icons/IconGithub.astro";
import IconLinkedin from "../components/icons/IconLinkedin.astro";
import IconGmail from "../components/icons/IconGmail.astro";
import IconWhatsApp from "../components/icons/IconWhatsApp.astro";
import IconWork from "../components/icons/IconWork.astro";
import IconProyects from "../components/icons/IconProyects.astro";
import IconAboutMe from "../components/icons/IconAboutMe.astro";
import IconLeadership from "../components/icons/IconLeadership.astro";

import Layout from "../layouts/Layout.astro";

import Badges from "../components/Badges.astro";
import SectionConteiner from "../components/SectionConteiner.astro";
import Maintag from "../components/Maintag.astro";
import Experience from "../components/Experience.astro";
import Proyect from "../components/Proyect.astro";
import AboutMe from "../components/AboutMe.astro";
import Leadership from "../components/Leadership.astro";
import IconDownload from "../components/icons/IconDownload.astro";
import IconLanguage from "../components/icons/IconLanguage.astro";
---

<Layout
	title="Portafolio - Aldo Leonel Zunino Becerra - Full Stack Developer"
	description="Portafolio de Aldo Leonel Zunino Becerra, programador y desarrollador full stack, especializado en desarrollo web y automatización de procesos, impulsando la adopción de herramientas de IA y mentoría técnica.."
>
	<main class="px-4">
		<SectionConteiner class="mt-10 py-18 pb-20">
			<img
				class="rounded-4xl w-2xs h-2xs mb-6"
				src="https://avatars.githubusercontent.com/u/175363752?v=4"
				alt="principal logo"
			/>
			<h1
				class="text-2xl lg:text-4xl md:text-4xl font-bold text-white text-center mt-10 flex flex-row gap-x-5 pb-6"
			>
				Aldo Leonel Zunino Becerra <a
					href="https://www.linkedin.com/in/aldo-leonel-zunino-becerra/"
					target="_blank"
					class="flex justify-center items-center"
					><Maintag>Disponible Para Trabajar</Maintag></a
				>
			</h1>
			<h2 class="text-xl md:text-3xl opacity-70">
				Desarrollador Full Stack.
			</h2>
			<h3
				class="text-base md:text-lg opacity-60 text-center text-pretty mt-2 max-w-2xl"
			>
				Especializado en la creación de soluciones web y automatización
				de procesos. Utilizo la Inteligencia Artificial como aliada para
				optimizar mi código y maximizar resultados. Complemento mi
				perfil técnico con una fuerte vocación por el liderazgo y la
				mentoría.
			</h3>

			<nav class="flex gap-4 mt-8 flex-wrap justify-center">
				<Badges
					href="https://www.linkedin.com/in/aldo-leonel-zunino-becerra/"
					target="_blank"
				>
					<IconLinkedin class="size-3 md:size-5" />
					LinkedIn
				</Badges>

				<Badges href="https://github.com/ZuninoAldo" target="_blank">
					<IconGithub class="size-3 md:size-5" />
					GitHub
				</Badges>

				<Badges href="mailto:zunino.aldo@gmail.com">
					<IconGmail class="size-3 md:size-5" />
					zunino.aldo@gmail.com
				</Badges>

				<Badges href="https://wa.me/+5491162063047" target="_blank">
					<IconWhatsApp class="size-3 md:size-5" />
					WhatsApp
				</Badges>

				<Badges
					href="/Cv/CV-Zunino-Becerra-Aldo.pdf"
					download="CV-Zunino-Becerra-Aldo"
				>
					<IconDownload class="size-3 md:size-5" />
					Descargar CV
				</Badges>

				<Badges>
					<IconLanguage class="size-3 md:size-5" />
					English B2
				</Badges>
			</nav>
		</SectionConteiner>

		<SectionConteiner id="experiencia" class="py-20 pb-20">
			<h2
				class="text-3xl font-semibold text-white opacity-70 mb-10 flex justify-center md:justify-start gap-x-3 items-center"
			>
				<IconWork class="size-8" />
				Experiencia Laboral
			</h2>
			<Experience />
		</SectionConteiner>

		<SectionConteiner id="proyectos" class="py-20 pb-20">
			<h2
				class="text-3xl font-semibold text-white opacity-70 mb-10 flex justify-center md:justify-start gap-x-3 items-center"
			>
				<IconProyects class="size-8" />
				Proyectos Personales
			</h2>
			<Proyect />
		</SectionConteiner>

		<SectionConteiner id="sobremi" class="py-20 pb-20">
			<h2
				class="text-4xl font-semibold text-white opacity-70 mb-10 flex justify-center md:justify-start gap-x-3 items-center"
			>
				<IconAboutMe class="size-10" />
				Sobre Mi
			</h2>
			<AboutMe />
		</SectionConteiner>

		<SectionConteiner id="liderazgo" class="py-20 pb-20">
			<h2
				class="text-4xl font-semibold text-white opacity-70 mb-10 flex justify-center md:justify-start gap-x-3 items-center"
			>
				<IconLeadership class="size-10" />
				Liderazgo y Mentoría
			</h2>
			<Leadership />
		</SectionConteiner>
	</main>
</Layout>
