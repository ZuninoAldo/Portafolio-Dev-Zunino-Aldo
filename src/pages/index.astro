---
import Maintag from '../components/Maintag.astro';
import Layout from '../layouts/Layout.astro';

---

<Layout title="Astro Basics">
	<main>
		<section class="w-full mx-auto flex flex-col items-center lg:max-w-4xl py-18">
			<img class="rounded-4xl w-2xs h-2xs mb-6" src="https://avatars.githubusercontent.com/u/175363752?v=4" alt="principal logo">
		<h1 class="text-4xl font-bold text-white text-center mt-10 flex flex-row gap-x-5 pb-7">Aldo Leonel Zunino Becerra <a href="https://www.linkedin.com/in/aldo-leonel-zunino-becerra/" target="_blank" class="flex justify-center items-center"><Maintag>Ready To Work</Maintag></a> </h1>
		<h2 class="text-xl opacity-70">Full Stack Developer.</h2>
		<h2 class="text-xl opacity-60">Especializado en Desarrollo Web, IA y Automatizaciones.</h2>
		</section>
	</main>
</Layout>
