---
const { title, description, date, enterprise } = Astro.props;
---

<span
    class="absolute flex items-center justify-center w-6 h-6 bg-brand-softer rounded-full -inset-s-3 ring-8 ring-buffer"
>
    <svg
        class="size-5 text-fg-brand-strong"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        fill="currentColor"
        viewBox="0 0 24 24"
        ><path
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 10h16m-8-3V4M7 7V4m10 3V4M5 20h14a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1H5a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1Zm3-7h.01v.01H8V13Zm4 0h.01v.01H12V13Zm4 0h.01v.01H16V13Zm-8 4h.01v.01H8V17Zm4 0h.01v.01H12V17Zm4 0h.01v.01H16V17Z"
        ></path></svg
    >
</span>
<time
    class="bg-neutral-secondary-medium border border-default-medium text-heading text-xs font-medium px-1.5 py-0.5 rounded"
    >{date}</time
>
<h3 class="my-3 text-lg font-semibold text-white opacity-70">{title}</h3>
<h4 class="my-3 text-l font-medium text-fg-brand-strong opacity-90">{enterprise}</h4>
<p class="text-white opacity-80 text-pretty">{description}</p>
